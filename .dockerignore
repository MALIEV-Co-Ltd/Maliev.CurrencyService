# .dockerignore file for CurrencyService

# Git
.git
.gitignore
.gitattributes

# Documentation
README.md
CHANGELOG.md
LICENSE
*.md

# IDE and editor files
.vs/
.vscode/
*.user
*.suo
*.userprefs
.idea/

# Build outputs
**/bin/
**/obj/
**/out/
**/TestResults/

# Package managers
**/packages/
node_modules/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# Runtime data
pids
*.pid
*.seed

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Temporary folders
tmp/
temp/

# Test files and directories
**/*Tests/
**/*.Tests/
**/TestResults/

# GitHub workflows (not needed in container)
.github/

# CI/CD files
*.yml
*.yaml
docker-compose*.yml

# Local environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Secrets
secrets.yaml
secrets.json

# Speckit documentation (not needed in container)
.specify/
.claude/
specs/

# Monitoring assets (not needed in runtime container)
monitoring/

# Additional .NET artifacts
**/*.DotSettings
**/*.DotSettings.user
**/launchSettings.json
**/Properties/launchSettings.json

# NuGet packages (restored during build)
*.nupkg
*.snupkg

# Entity Framework migrations temporary files
**/Migrations/*.Designer.cs.bak

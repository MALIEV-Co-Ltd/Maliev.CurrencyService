{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Maliev.CurrencyService.Api.Services": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": ""
  },
  "Cache": {
    "CurrencyCacheDurationMinutes": 60,
    "SearchCacheDurationMinutes": 30,
    "MaxCacheSize": 1000
  },
  "ExchangeRate": {
    "CacheDurationMinutes": 30,
    "RetryAttempts": 3,
    "TimeoutSeconds": 30,
    "ProviderOrder": [
      "Fawazahmed",
      "Frankfurter"
    ]
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "SecurityKey": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
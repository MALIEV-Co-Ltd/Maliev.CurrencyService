{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "CurrencyDbContext": "Server=localhost;Port=5432;Database=currency_app_db;User Id=postgres;Password=postgres123;"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "Enabled": false
  },
  "ExternalProviders": {
    "ProviderOrder": [
      "Fawazahmed",
      "Frankfurter"
    ],
    "IntermediaryOrder": [
      "USD",
      "EUR",
      "GBP"
    ],
    "Timeout": "00:00:10"
  },
  "Caching": {
    "LiveRateTtlSeconds": 60,
    "SnapshotRateTtlSeconds": 300,
    "StaleGracePeriodSeconds": 60,
    "InProcessCacheSize": 1000
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1,
    "QueueLimit": 20
  }
}
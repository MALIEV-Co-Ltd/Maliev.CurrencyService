{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "None",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.Watch": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CurrencyDbContext": "Server=localhost;Port=5432;Database=currency_app_db;User Id=postgres;Password=OVERRIDE_WITH_SECRET;"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "ExternalProviders": {
    "ProviderOrder": [
      "Fawazahmed",
      "Frankfurter"
    ],
    "IntermediaryOrder": [
      "USD",
      "EUR",
      "GBP"
    ],
    "Timeout": "00:00:10"
  },
  "Caching": {
    "LiveRateTtlSeconds": 60,
    "SnapshotRateTtlSeconds": 300,
    "StaleGracePeriodSeconds": 60,
    "InProcessCacheSize": 1000
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1,
    "QueueLimit": 20
  }
}